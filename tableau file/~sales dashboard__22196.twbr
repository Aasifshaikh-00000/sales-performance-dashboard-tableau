              <calculation class='tableau' formula='IF SUM([Calculation_0952750604095488]) = WINDOW_MAX(SUM([Calculation_0952750604095488])) THEN SUM([Calculation_0952750604095488])&#13;&#10;ELSEIF SUM([Calculation_0952750604095488]) = WINDOW_MIN(SUM([Calculation_0952750604095488])) THEN SUM([Calculation_0952750604095488])&#13;&#10;END'>
