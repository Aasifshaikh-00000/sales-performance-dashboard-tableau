              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0952750605627395]-1 THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='CY sales' datatype='real' default-format='n&quot;$&quot;#,##0,K;-&quot;$&quot;#,##0,K' name='[Calculation_0952750604095488]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 0952750605627395] THEN [Sales]&#13;&#10;END' />
